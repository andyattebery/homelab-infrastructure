{
  "uid": "zfs-pools",
  "title": "ZFS Pools",
  "description": "ZFS pool health, capacity, fragmentation, and scrub status across nas-01 and backup-01",
  "tags": ["zfs", "storage"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "1m",
  "schemaVersion": 39,
  "panels": [
    {
      "type": "stat",
      "title": "Pool Health",
      "description": "0 = ONLINE (healthy)",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
      "targets": [
        {
          "expr": "label_replace(zfs_pool_health, \"host\", \"$1\", \"instance\", \"([^.:]+).*\")",
          "legendFormat": "{{ host }} / {{ pool }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": {
              "0": { "text": "ONLINE", "color": "green" },
              "1": { "text": "DEGRADED", "color": "red" },
              "2": { "text": "FAULTED", "color": "dark-red" },
              "3": { "text": "OFFLINE", "color": "orange" },
              "4": { "text": "UNAVAIL", "color": "dark-red" },
              "5": { "text": "REMOVED", "color": "purple" }
            }}
          ],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "horizontal"
      }
    },
    {
      "type": "stat",
      "title": "Scrub Status",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
      "targets": [
        {
          "expr": "label_replace(zpool_scrub_in_progress, \"host\", \"$1\", \"instance\", \"([^.:]+).*\")",
          "legendFormat": "{{ host }} / {{ pool }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": {
              "0": { "text": "Idle", "color": "green" },
              "1": { "text": "Scrubbing", "color": "blue" }
            }}
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "horizontal"
      }
    },
    {
      "type": "stat",
      "title": "Scrub Errors",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
      "targets": [
        {
          "expr": "label_replace(zpool_scrub_errors, \"host\", \"$1\", \"instance\", \"([^.:]+).*\")",
          "legendFormat": "{{ host }} / {{ pool }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "horizontal"
      }
    },
    {
      "type": "gauge",
      "title": "Pool Usage",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
      "targets": [
        {
          "expr": "label_replace(zfs_pool_allocated_bytes / zfs_pool_size_bytes, \"host\", \"$1\", \"instance\", \"([^.:]+).*\")",
          "legendFormat": "{{ host }} / {{ pool }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.75 },
            { "color": "red", "value": 0.9 }
          ]}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "type": "gauge",
      "title": "Pool Fragmentation",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
      "targets": [
        {
          "expr": "label_replace(zfs_pool_fragmentation_ratio, \"host\", \"$1\", \"instance\", \"([^.:]+).*\")",
          "legendFormat": "{{ host }} / {{ pool }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.5 },
            { "color": "red", "value": 0.75 }
          ]}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "type": "timeseries",
      "title": "Pool Allocated Over Time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
      "targets": [
        {
          "expr": "label_replace(zfs_pool_allocated_bytes, \"host\", \"$1\", \"instance\", \"([^.:]+).*\")",
          "legendFormat": "{{ host }} / {{ pool }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 10, "lineWidth": 2, "spanNulls": false },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "type": "timeseries",
      "title": "Top Datasets by Usage",
      "description": "Top 10 datasets by used bytes (filesystem type only)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
      "targets": [
        {
          "expr": "label_replace(topk(10, zfs_dataset_used_by_dataset_bytes{type=\"filesystem\"}), \"host\", \"$1\", \"instance\", \"([^.:]+).*\")",
          "legendFormat": "{{ host }} / {{ name }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 10, "lineWidth": 2, "spanNulls": false },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    }
  ],
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "links": []
}
