{
  "uid": "nut-ups",
  "title": "NUT UPS",
  "description": "UPS status via DRuggeri/nut_exporter (network_ups_tools_* metrics)",
  "tags": ["ups", "nut"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 39,
  "panels": [
    {
      "type": "row",
      "title": "Status",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Power",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
      "targets": [
        {
          "expr": "network_ups_tools_ups_status{flag=\"OL\"}",
          "legendFormat": "{{ ups }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "Online", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "On Battery", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "type": "stat",
      "title": "Battery",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
      "targets": [
        {
          "expr": "network_ups_tools_battery_charge",
          "legendFormat": "{{ ups }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 25 }, { "color": "yellow", "value": 50 }, { "color": "green", "value": 80 }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value"
      }
    },
    {
      "type": "stat",
      "title": "Runtime",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
      "targets": [
        {
          "expr": "network_ups_tools_battery_runtime",
          "legendFormat": "{{ ups }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 300 }, { "color": "yellow", "value": 600 }, { "color": "green", "value": 1200 }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value"
      }
    },
    {
      "type": "stat",
      "title": "Load",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
      "targets": [
        {
          "expr": "network_ups_tools_ups_load",
          "legendFormat": "{{ ups }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "orange", "value": 80 }, { "color": "red", "value": 90 }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value"
      }
    },
    {
      "type": "stat",
      "title": "Input V",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
      "targets": [
        {
          "expr": "network_ups_tools_input_voltage",
          "legendFormat": "{{ ups }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "volt",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 100 }, { "color": "green", "value": 110 }, { "color": "green", "value": 130 }, { "color": "red", "value": 140 }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value"
      }
    },
    {
      "type": "stat",
      "title": "Output V",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
      "targets": [
        {
          "expr": "network_ups_tools_output_voltage",
          "legendFormat": "{{ ups }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "volt",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 100 }, { "color": "green", "value": 110 }, { "color": "green", "value": 130 }, { "color": "red", "value": 140 }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value"
      }
    },
    {
      "type": "row",
      "title": "History",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Battery Charge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
      "targets": [
        {
          "expr": "network_ups_tools_battery_charge",
          "legendFormat": "Charge",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "fillOpacity": 10, "lineWidth": 2, "spanNulls": false },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 25 }, { "color": "yellow", "value": 50 }, { "color": "green", "value": 80 }] },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "type": "timeseries",
      "title": "Runtime Remaining",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
      "targets": [
        {
          "expr": "network_ups_tools_battery_runtime",
          "legendFormat": "Runtime",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": { "fillOpacity": 10, "lineWidth": 2, "spanNulls": false },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 300 }, { "color": "yellow", "value": 600 }, { "color": "green", "value": 1200 }] },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "type": "timeseries",
      "title": "Input / Output Voltage",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
      "targets": [
        {
          "expr": "network_ups_tools_input_voltage",
          "legendFormat": "Input",
          "refId": "A"
        },
        {
          "expr": "network_ups_tools_output_voltage",
          "legendFormat": "Output",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "volt",
          "custom": { "fillOpacity": 5, "lineWidth": 2, "spanNulls": false },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "type": "timeseries",
      "title": "Load / Battery Voltage",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
      "targets": [
        {
          "expr": "network_ups_tools_ups_load",
          "legendFormat": "Load %",
          "refId": "A"
        },
        {
          "expr": "network_ups_tools_battery_voltage",
          "legendFormat": "Battery V",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 5, "lineWidth": 2, "spanNulls": false },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "Load" },
            "properties": [{ "id": "unit", "value": "percent" }, { "id": "custom.axisPlacement", "value": "left" }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "Battery V" },
            "properties": [{ "id": "unit", "value": "volt" }, { "id": "custom.axisPlacement", "value": "right" }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    }
  ],
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "links": []
}
