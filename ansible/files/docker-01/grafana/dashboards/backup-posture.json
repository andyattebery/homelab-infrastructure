  },
  "description": "ZFS pool health, PBS backup freshness, scrub state, Healthchecks sync status",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "ZFS Pools",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "green", "text": "Online" } }, "type": "value" },
            { "options": { "1": { "color": "red", "text": "Degraded" } }, "type": "value" },
            { "options": { "2": { "color": "dark-red", "text": "Faulted" } }, "type": "value" },
            { "options": { "3": { "color": "orange", "text": "Offline" } }, "type": "value" },
            { "options": { "4": { "color": "dark-red", "text": "Unavail" } }, "type": "value" },
            { "options": { "5": { "color": "orange", "text": "Removed" } }, "type": "value" },
            { "options": { "6": { "color": "dark-red", "text": "Suspended" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
          "expr": "label_replace(zfs_pool_health, \"host\", \"$1\", \"instance\", \"([^.:]+).*\")",
          "legendFormat": "{{host}} / {{pool}}",
          "refId": "A"
        }
      ],
      "title": "Pool Health",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.75 },
              { "color": "red", "value": 0.85 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 5 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
          "expr": "label_replace(zfs_pool_allocated_bytes / zfs_pool_size_bytes, \"host\", \"$1\", \"instance\", \"([^.:]+).*\")",
          "legendFormat": "{{host}} / {{pool}}",
          "refId": "A"
        }
      ],
      "title": "Pool Usage",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 5 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
          "expr": "label_replace(zfs_pool_free_bytes, \"host\", \"$1\", \"instance\", \"([^.:]+).*\")",
          "legendFormat": "{{host}} / {{pool}}",
          "refId": "A"
        }
      ],
      "title": "Pool Free Space",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 },
      "id": 5,
      "title": "ZFS Scrubs",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Last Scrub" },
            "properties": [
              { "id": "unit", "value": "dateTimeFromNow" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Errors" },
            "properties": [
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "In Progress" },
            "properties": [
              { "id": "mappings", "value": [{ "options": { "0": { "text": "No" }, "1": { "color": "blue", "text": "Yes" } }, "type": "value" }] },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 12 },
      "id": 6,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
          "expr": "label_join(label_replace(zpool_last_scrub_timestamp * 1000, \"host\", \"$1\", \"instance\", \"([^.:]+).*\"), \"host_pool\", \" / \", \"host\", \"pool\")",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
          "expr": "label_join(label_replace(zpool_scrub_errors, \"host\", \"$1\", \"instance\", \"([^.:]+).*\"), \"host_pool\", \" / \", \"host\", \"pool\")",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
          "expr": "label_join(label_replace(zpool_scrub_in_progress, \"host\", \"$1\", \"instance\", \"([^.:]+).*\"), \"host_pool\", \" / \", \"host\", \"pool\")",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "C"
        }
      ],
      "title": "Scrub Status",
      "transformations": [
        {
          "id": "seriesToColumns",
          "options": { "byField": "host_pool" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "__name__ 1": true,
              "__name__ 2": true,
              "__name__ 3": true,
              "job 1": true,
              "job 2": true,
              "job 3": true,
              "instance 1": true,
              "instance 2": true,
              "instance 3": true,
              "pool 1": true,
              "pool 2": true,
              "pool 3": true,
              "host 1": true,
              "host 2": true,
              "host 3": true
            },
            "renameByName": {
              "host_pool": "Host / Pool",
              "Value #A": "Last Scrub",
              "Value #B": "Errors",
              "Value #C": "In Progress"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "id": 7,
      "title": "PBS Backups",
