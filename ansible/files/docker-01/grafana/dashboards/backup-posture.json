        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
          "expr": "zfs_pool_allocated_bytes{instance=~\"offsite-nas.*\"} / zfs_pool_size_bytes{instance=~\"offsite-nas.*\"}",
          "legendFormat": "{{pool}}",
          "refId": "A"
        }
      ],
      "title": "Offsite-NAS Pool Usage",
      "type": "stat"
