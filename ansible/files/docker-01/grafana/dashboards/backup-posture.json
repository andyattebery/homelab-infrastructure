    },
    {
      "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.75 },
              { "color": "red", "value": 0.85 }
            ]
          },
          "max": 1,
          "min": 0,
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 20 },
      "id": 8,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
          "expr": "pbs_used / pbs_size",
          "legendFormat": "{{datastore}}",
          "refId": "A"
        }
      ],
      "title": "PBS Datastore Usage",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 20 },
      "id": 9,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
          "expr": "pbs_available",
          "legendFormat": "{{datastore}}",
          "refId": "A"
        }
      ],
      "title": "PBS Free Space",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 20 },
      "id": 10,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
          "expr": "pbs_up",
          "legendFormat": "PBS",
          "refId": "A"
        }
      ],
      "title": "PBS Status",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Age" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 86400 }, { "color": "red", "value": 129600 }] } },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 24 },
      "id": 11,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Age" }]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "fe8ew4zkvbf28a" },
          "expr": "time() - pbs_snapshot_vm_last_timestamp",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Last Backup Age per VM",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true
            },
            "renameByName": {
              "vm_name": "VM",
              "namespace": "PVE Node",
              "datastore": "Datastore",
              "vm_id": "VM ID",
              "Value": "Age"
            },
            "indexByName": {
              "vm_name": 0,
              "namespace": 1,
              "vm_id": 2,
              "datastore": 3,
              "Value": 4
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "id": 12,
      "title": "Healthchecks (Syncoid & Cron)",
      "type": "row"
    },
    {
      "datasource": { "type": "influxdb", "uid": "influxdb-healthchecks" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "status" },
            "properties": [
              { "id": "mappings", "value": [
                { "options": { "up": { "color": "green", "text": "up" }, "down": { "color": "red", "text": "down" }, "grace": { "color": "yellow", "text": "grace" }, "paused": { "color": "blue", "text": "paused" }, "new": { "color": "purple", "text": "new" } }, "type": "value" }
              ]},
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "last_ping" },
            "properties": [
              { "id": "custom.width", "value": 200 }
            ]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 34 },
      "id": 13,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-healthchecks" },
          "query": "from(bucket: \"healthchecks\")\n  |> range(start: -24h)\n  |> filter(fn: (r) => r._measurement == \"healthchecks\")\n  |> filter(fn: (r) => r._field == \"status\" or r._field == \"n_pings\" or r._field == \"last_ping\")\n  |> last()\n  |> toString()\n  |> group()\n  |> pivot(rowKey: [\"_time\", \"name\"], columnKey: [\"_field\"], valueColumn: \"_value\")",
          "refId": "A"
        }
      ],
      "title": "Healthchecks Status",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "_start": true,
              "_stop": true,
              "_time": true,
              "_measurement": true,
              "host": true,
              "result": true,
              "table": true,
              "url": true
            },
            "renameByName": {
              "name": "Check",
              "last_ping": "Last Ping",
              "status": "Status",
              "n_pings": "Total Pings"
            },
            "indexByName": {
              "name": 0,
              "status": 1,
              "last_ping": 2,
              "n_pings": 3
            }
          }
        }
      ],
      "type": "table"
    },
    {
