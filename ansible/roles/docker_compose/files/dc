#!/usr/bin/env sh

: "${DOCKER_COMPOSE_DIR:=/opt/docker-compose}"

docker_compose_files_parameter=""
docker_compose_files_list=""
has_files_in_current_dir=false

# Look for docker-compose files in current directory
for f in docker-compose*.y*ml; do
    # Check if file actually exists (glob doesn't match returns pattern itself)
    if [ -f "$f" ]; then
        docker_compose_files_parameter="${docker_compose_files_parameter} --file ${f}"
        docker_compose_files_list="${docker_compose_files_list}  ${f}\n"
        has_files_in_current_dir=true
    fi
done

# If no files found in current directory and DOCKER_COMPOSE_DIR is set, check there
if [ "$has_files_in_current_dir" = false ] && [ -d "$DOCKER_COMPOSE_DIR" ]; then
    docker_compose_files_parameter="${docker_compose_files_parameter} --env-file ${DOCKER_COMPOSE_DIR}/.env"

    for f in "$DOCKER_COMPOSE_DIR"/docker-compose*.y*ml; do
        if [ -f "$f" ]; then
            docker_compose_files_parameter="${docker_compose_files_parameter} --file ${f}"
            docker_compose_files_list="${docker_compose_files_list}  ${f}\n"
        fi
    done
fi

printf "Running docker compose with files:\n${docker_compose_files_list}"

docker compose $docker_compose_files_parameter "$@"