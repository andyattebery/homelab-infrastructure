{% if remote_power_control_pikvm_url is defined %}
REMOTE_POWER_CONTROL_PIKVM_URL="{{ remote_power_control_pikvm_url }}"
{% endif %}
{% if remote_power_control_pikvm_username is defined %}
REMOTE_POWER_CONTROL_PIKVM_USERNAME="{{ remote_power_control_pikvm_username }}"
{% endif %}
{% if remote_power_control_pikvm_password is defined %}
REMOTE_POWER_CONTROL_PIKVM_PASSWORD="{{ remote_power_control_pikvm_password }}"
{% endif %}
{% if remote_power_control_homeassistant_url is defined %}
REMOTE_POWER_CONTROL_HOMEASSISTANT_URL="{{ remote_power_control_homeassistant_url }}"
{% endif %}
{% if remote_power_control_homeassistant_access_token is defined %}
REMOTE_POWER_CONTROL_HOMEASSISTANT_ACCESS_TOKEN="{{ remote_power_control_homeassistant_access_token }}"
{% endif %}
{% if remote_power_control_ssh_username is defined %}
REMOTE_POWER_CONTROL_SSH_USERNAME="{{ remote_power_control_ssh_username }}"
{% endif %}
{% if remote_power_control_ssh_private_key_path is defined %}
REMOTE_POWER_CONTROL_SSH_PRIVATE_KEY_PATH="{{ remote_power_control_ssh_private_key_path }}"
{% endif %}
{% if remote_power_control_post_power_on_max_wait_in_seconds is defined %}
REMOTE_POWER_CONTROL_POST_POWER_ON_MAX_WAIT_IN_SECONDS="{{ remote_power_control_post_power_on_max_wait_in_seconds }}"
{% endif %}
{% if remote_power_control_post_reboot_max_wait_in_seconds is defined %}
REMOTE_POWER_CONTROL_POST_REBOOT_MAX_WAIT_IN_SECONDS="{{ remote_power_control_post_reboot_max_wait_in_seconds }}"
{% endif %}
{% for env in remote_power_control_extra_envs | default({}) | dict2items %}
{{ env.key }}={{ env.value }}
{% endfor %}
